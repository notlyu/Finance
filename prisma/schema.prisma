generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int                    @id @default(autoincrement())
  email               String                 @unique
  password_hash       String
  name                String
  family_id           Int?
  created_at          DateTime               @default(now())
  budget              Budget[]
  familyInvites       FamilyInvite[]         @relation("CreatedInvites")
  goals               Goal[]
  goalContributions   GoalContribution[]
  recurring           RecurringTransaction[]
  safetyPillowHistory SafetyPillowHistory[]
  safetyPillowSetting SafetyPillowSetting?
  transactions        Transaction[]
  family              Family?                @relation(fields: [family_id], references: [id])
  wishes              Wish[]
  wishContributions   WishContribution[]
}

model Family {
  id            Int                    @id @default(autoincrement())
  name          String
  invite_code   String                 @unique
  owner_user_id Int
  created_at    DateTime               @default(now())
  budgets       Budget[]
  invites       FamilyInvite[]
  goals         Goal[]
  recurring     RecurringTransaction[]
  transactions  Transaction[]
  members       User[]
  wishes        Wish[]
}

model FamilyInvite {
  id         Int       @id @default(autoincrement())
  family_id  Int
  code       String    @unique
  created_by Int
  expires_at DateTime?
  created_at DateTime  @default(now())
  creator    User      @relation("CreatedInvites", fields: [created_by], references: [id])
  family     Family    @relation(fields: [family_id], references: [id])
}

model Category {
  id           Int                    @id @default(autoincrement())
  name         String
  type         String
  icon         String?
  color        String?
  user_id      Int?
  is_system    Boolean                @default(false)
  family_id    Int?
  budgets      Budget[]
  goals        Goal[]
  recurring    RecurringTransaction[]
  transactions Transaction[]
  wishes       Wish[]
}

model Transaction {
  id                Int                @id @default(autoincrement())
  user_id           Int
  family_id         Int?
  category_id       Int
  amount            Decimal            @db.Decimal(12, 2)
  type              String
  date              DateTime
  comment           String?
  is_private        Boolean            @default(false)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @default(now())
  goalContributions GoalContribution[]
  category          Category           @relation(fields: [category_id], references: [id])
  family            Family?            @relation(fields: [family_id], references: [id])
  user              User               @relation(fields: [user_id], references: [id])
  wishContributions WishContribution[]
}

model Goal {
  id                      Int                @id @default(autoincrement())
  user_id                 Int
  family_id               Int?
  name                    String
  target_amount           Decimal            @db.Decimal(12, 2)
  current_amount          Decimal            @default(0) @db.Decimal(12, 2)
  deadline                DateTime?
  category_id             Int?
  is_archived             Boolean            @default(false)
  created_at              DateTime           @default(now())
  updated_at              DateTime           @default(now())
  auto_contribute_enabled Boolean            @default(false)
  auto_contribute_type    String?
  auto_contribute_value   Decimal?           @db.Decimal(12, 2)
  category                Category?          @relation(fields: [category_id], references: [id])
  family                  Family?            @relation(fields: [family_id], references: [id])
  user                    User               @relation(fields: [user_id], references: [id])
  contributions           GoalContribution[]
}

model GoalContribution {
  id             Int          @id @default(autoincrement())
  goal_id        Int
  user_id        Int
  amount         Decimal      @db.Decimal(12, 2)
  created_at     DateTime     @default(now())
  transaction_id Int?
  goal           Goal         @relation(fields: [goal_id], references: [id])
  transaction    Transaction? @relation(fields: [transaction_id], references: [id])
  user           User         @relation(fields: [user_id], references: [id])
}

model WishContribution {
  id             Int          @id @default(autoincrement())
  wish_id        Int
  user_id        Int
  amount         Decimal      @db.Decimal(12, 2)
  created_at     DateTime     @default(now())
  transaction_id Int?
  transaction    Transaction? @relation(fields: [transaction_id], references: [id])
  user           User         @relation(fields: [user_id], references: [id])
  wish           Wish         @relation(fields: [wish_id], references: [id])
}

model Wish {
  id            Int                @id @default(autoincrement())
  user_id       Int
  family_id     Int?
  name          String
  cost          Decimal            @db.Decimal(12, 2)
  saved_amount  Decimal            @default(0) @db.Decimal(12, 2)
  priority      Int                @default(3)
  status        String             @default("active")
  category_id   Int?
  is_private    Boolean            @default(true)
  archived      Boolean            @default(false)
  archived_at   DateTime?
  created_at    DateTime           @default(now())
  updated_at    DateTime           @default(now())
  category      Category?          @relation(fields: [category_id], references: [id])
  family        Family?            @relation(fields: [family_id], references: [id])
  user          User               @relation(fields: [user_id], references: [id])
  contributions WishContribution[]
}

model Budget {
  id          Int      @id @default(autoincrement())
  user_id     Int
  family_id   Int?
  category_id Int
  month       String
  limit       Decimal  @db.Decimal(12, 2)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  category    Category @relation(fields: [category_id], references: [id])
  family      Family?  @relation(fields: [family_id], references: [id])
  user        User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, category_id, month, family_id])
}

model RecurringTransaction {
  id             Int      @id @default(autoincrement())
  user_id        Int
  family_id      Int?
  category_id    Int
  amount         Decimal  @db.Decimal(12, 2)
  type           String
  day_of_month   Int      @default(1)
  start_month    String
  comment        String?
  is_private     Boolean  @default(false)
  active         Boolean  @default(true)
  last_run_month String?
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())
  category       Category @relation(fields: [category_id], references: [id])
  family         Family?  @relation(fields: [family_id], references: [id])
  user           User     @relation(fields: [user_id], references: [id])
}

model SafetyPillowSetting {
  id         Int      @id @default(autoincrement())
  user_id    Int      @unique
  months     Int      @default(3)
  updated_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])
}

model SafetyPillowHistory {
  id             Int      @id @default(autoincrement())
  user_id        Int
  total_income   Decimal  @db.Decimal(12, 2)
  total_expenses Decimal  @db.Decimal(12, 2)
  safety_pillow  Decimal  @db.Decimal(12, 2)
  calculated_at  DateTime @default(now())
  user           User     @relation(fields: [user_id], references: [id])
}

model Notification {
  id           Int      @id @default(autoincrement())
  user_id      Int
  type         String
  title        String
  message      String
  read         Boolean  @default(false)
  data         Json?
  created_at   DateTime @default(now())
  related_id   Int?
  related_type String?
}

model NotificationSetting {
  id                     Int      @id @default(autoincrement())
  user_id                Int      @unique
  remind_upcoming        Boolean  @default(true)
  notify_goal_reached    Boolean  @default(true)
  notify_budget_exceeded Boolean  @default(true)
  notify_wish_completed  Boolean  @default(true)
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now())
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String
  expires_at DateTime
  created_at DateTime @default(now())
}
